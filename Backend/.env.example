# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Use your MongoDB Atlas connection string when deploying to Render:
# mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/earthquake_db

# ─── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET=your_admin_secret_key_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your frontend URL in production (e.g., https://your-app.vercel.app)
# Leave as * for open access during development
CORS_ORIGIN=*

# ─── Static Assets (optional) ─────────────────────────────────────────────────
# Absolute path to a folder served at /local-images. Leave blank to use default.
# LOCAL_IMAGES_PATH=/path/to/your/images
